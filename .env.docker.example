# Optional Docker overrides (repo root .env)
# Integration secrets (Spaces, WhatsApp, SMTP, etc.) live in backend/.env — loaded automatically.
#
# Copy to .env only if you need values here that differ from backend/.env:
#   cp .env.docker.example .env

# PostgreSQL container credentials (used by postgres service + DATABASE_URL in compose)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=affiniks_rms

# JWT — only needed here if not already set in backend/.env
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Seed
SEED_ADMIN_PASSWORD=admin123

# Logging
LOG_LEVEL=info

# Do NOT put these in root .env — compose overrides them for Docker networking:
# DATABASE_URL, REDIS_URL, REDIS_HOST, REDIS_PORT, PORT, CORS_ORIGIN

# Integration keys stay in backend/.env (no copy needed):
# DO_SPACES_*, WHATSAPP_*, META_*, SMTP_*, MSG91_*, GOOGLE_*, WEB_URL
