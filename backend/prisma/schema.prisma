model State {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique
  countryCode String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  clientsPhysicalAddress    Client[]    @relation("PhysicalAddressStateClient")
  usersPhysicalAddress      User[]      @relation("PhysicalAddressStateUser")
  candidatesPhysicalAddress Candidate[] @relation("PhysicalAddressStateCandidate")

  @@map("states")
}

enum LanguageProficiency {
  PRIMARY
  SECONDARY
  TERTIARY
}

enum RecruiterCountrySectorScope {
  HEALTHCARE
  NON_HEALTH_CARE
}

model Language {
  code      String   @id
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userLanguages UserLanguage[]

  @@index([isActive])
  @@map("languages")
}

model UserLanguage {
  id           String              @id @default(cuid())
  userId       String
  languageCode String
  proficiency  LanguageProficiency
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

