generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SessionAvailability {
  ACTIVE
  BREAK
  ON_CALL
}

enum ProjectStatus {
  COMPLETED
  ON_HOLD
  IN_PROGRESS
  CANCELLED
}

enum UserAccountStatus {
  ACTIVE
  INACTIVE
  BLOCKED
}

model RefreshToken {
  id        String    @id @default(cuid())
  familyId  String
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  hash      String
  user      User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model UserSession {
  id                    String              @id @default(cuid())
  userId                String
  refreshTokenId        String?
  ipAddress             String?
  userAgent             String?
  browser               String?
  os                    String?
  deviceType            String?
  loginAt               DateTime            @default(now())
  lastActivityAt        DateTime            @default(now())
  isActive              Boolean             @default(true)
  availability          SessionAvailability @default(ACTIVE)
  availabilityUpdatedAt DateTime?
  user                  User                @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([refreshTokenId])
  @@map("user_sessions")
}

model User {
  id                               String                         @id @default(cuid())
  employeeCode                     String?                        @unique @map("employee_code")
  email                            String                         @unique
  name                             String
  password                         String
  dateOfBirth                      DateTime?
  otp                              String?
  otpExpiresAt                     DateTime?
  createdAt                        DateTime                       @default(now())
  updatedAt                        DateTime                       @updatedAt
  countryCode                      String
  profileImage                     String?
  mobileNumber                     String
  auditLogs                        AuditLog[]
  notifications                    Notification[]
  createdProjects                  Project[]                      @relation("ProjectCreator")
  createdClients                   Client[]                       @relation("ClientCreator")
  refreshTokens                    RefreshToken[]
  sessions                         UserSession[]
  transferRequestsApproved         TeamTransferRequest[]          @relation("TransferApprover")
  transferRequestsRequested        TeamTransferRequest[]          @relation("TransferRequester")
  transferRequestsReceived         TeamTransferRequest[]          @relation("TransferUser")
  statusChangeRequestsRequested    CandidateProjectStatusChangeRequest[] @relation("StatusChangeRequester")
  statusChangeRequestsReviewed     CandidateProjectStatusChangeRequest[] @relation("StatusChangeReviewer")
  userRoles                        UserRole[]
  userTeams                        UserTeam[]
  candidateProjectMaps             CandidateProjects[]
  candidateRecruiterAssignments    CandidateRecruiterAssignment[]
  assignedByRecruiterAssignments   CandidateRecruiterAssignment[] @relation("AssignedByUser")
  unassignedByRecruiterAssignments CandidateRecruiterAssignment[] @relation("UnassignedByUser")
  createdByRecruiterAssignments    CandidateRecruiterAssignment[] @relation("CreatedByUser")

  // user preference: should notification sounds be muted?
  notificationSoundMuted Boolean @default(false)

  assignedProcessingTasks    ProcessingCandidate[] @relation("AssignedToProcessing")
  processingHistoryChanges   ProcessingHistory[]   @relation("UserToProcessingHistory")
  recruiterProcessingHistory ProcessingHistory[]   @relation("RecruiterToProcessingHistory")

  statusChanges               CandidateStatusHistory[]        @relation("UserToHistory")
  rnrReminders                RNRReminder[]                   @relation("RecruiterRNRReminders")
  callbackReminders           CallbackReminder[]              @relation("RecruiterCallbackReminders")
  processingRemindersAssigned ProcessingStepReminder[]
  projectStatusChanges        CandidateProjectStatusHistory[] @relation("UserToProjectStatusHistory")
  interviewStatusHistory      InterviewStatusHistory[]        @relation("UserToInterviewStatusHistory")
  documentVerificationActions DocumentVerificationHistory[]   @relation("DocumentVerificationPerformer")
  documentForwards            DocumentForwardHistory[]
  screenings                  Screening[]                     @relation("ScreeningCoordinator")
  agentCandidateRequests      AgentCandidateRequest[]         @relation("AgentCandidateRequestRequester")

  addressCountryCode String?
  addressStateId     String?
  address            String?
  addressCountry     Country? @relation("PhysicalAddressCountryUser", fields: [addressCountryCode], references: [code], onDelete: SetNull)
  addressState       State?   @relation("PhysicalAddressStateUser", fields: [addressStateId], references: [id], onDelete: SetNull)

  userLanguages         UserLanguage[]
  userCountryCoverages  UserCountryCoverage[]
  userProfessionScopes  UserProfessionScope[]

  accountStatus          UserAccountStatus          @default(ACTIVE) @map("account_status")
  accountStatusUpdatedAt DateTime?                  @map("account_status_updated_at")
  accountStatusChanges   UserAccountStatusHistory[] @relation("UserAccountStatusSubject")
  statusChangesPerformed UserAccountStatusHistory[] @relation("UserAccountStatusChangedBy")

  @@unique([countryCode, mobileNumber])
  @@index([email])
  @@index([countryCode, mobileNumber])
  @@index([addressCountryCode])
  @@index([addressStateId])
  @@index([createdAt])
  @@index([employeeCode])
  @@index([accountStatus])
  @@map("users")
}

model UserAccountStatusHistory {
  id             String             @id @default(cuid())
  userId         String             @map("user_id")
  user           User               @relation("UserAccountStatusSubject", fields: [userId], references: [id], onDelete: Cascade)
  previousStatus UserAccountStatus? @map("previous_status")
  newStatus      UserAccountStatus  @map("new_status")
  remarks        String             @db.Text
  changedById    String?            @map("changed_by_id")
  changedBy      User?              @relation("UserAccountStatusChangedBy", fields: [changedById], references: [id], onDelete: SetNull)
  createdAt      DateTime           @default(now()) @map("created_at")

  @@index([userId])
  @@index([changedById])
  @@index([createdAt])
  @@map("user_account_status_history")
}

model EmployeeCodeSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("employee_code_sequences")
}

model Role {
  id              String           @id @default(cuid())
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]
  userRoles       UserRole[]

  @@map("roles")
}

model Permission {
  id              String           @id @default(cuid())
  key             String           @unique
  description     String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Team {
  id                   String                @id @default(cuid())
  name                 String                @unique
  leadId               String?
  headId               String?
  managerId            String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  candidates           Candidate[]
  projects             Project[]
  transferRequestsFrom TeamTransferRequest[] @relation("FromTeamTransfers")
  transferRequestsTo   TeamTransferRequest[] @relation("ToTeamTransfers")
  userTeams            UserTeam[]

  @@map("teams")
}

model UserTeam {
  userId String
  teamId String
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, teamId])
  @@map("user_teams")
}

model Client {
  id                 String                  @id @default(cuid())
  name               String
  pointOfContact     String?
  email              String?
  phone              String?
  address            String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  acquisitionMethod  AcquisitionMethod?
  agencyType         AgencyType?
  billingAddress     String?
  commissionRate     Float?
  contractEndDate    DateTime?
  contractStartDate  DateTime?
  facilitySize       FacilitySize?
  facilityType       FacilityType?
  locations          Json                    @default("[]")
  organization       String?
  paymentTerms       String?
  profession         String?
  relationship       IndividualRelationship?
  relationshipType   RelationshipType?
  sourceName         String?
  sourceNotes        String?
  sourceType         ExternalSourceType?
  specialties        Json                    @default("[]")
  taxId              String?
  type               ClientType
  createdBy          String?
  addressCountryCode String?
  addressStateId     String?
  addressCountry     Country?                @relation("PhysicalAddressCountryClient", fields: [addressCountryCode], references: [code], onDelete: SetNull)
  addressState       State?                  @relation("PhysicalAddressStateClient", fields: [addressStateId], references: [id], onDelete: SetNull)
  creator            User?                   @relation("ClientCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  projects           Project[]
  subClientLinks     ClientSubClient[]       @relation("ClientSubClientParent")
  parentClientLinks  ClientSubClient[]       @relation("ClientSubClientChild")

  @@index([addressCountryCode])
  @@index([addressStateId])
  @@index([createdBy])
  @@map("clients")
}

/// Parent intermediary (SUB_AGENT | FREELANCE) → child end client (typically DIRECT_CLIENT).
model ClientSubClient {
  id             String                  @id @default(cuid())
  parentClientId String
  childClientId  String
  linkType       ClientSubClientLinkType
  createdAt      DateTime                @default(now())

  parent Client @relation("ClientSubClientParent", fields: [parentClientId], references: [id], onDelete: Cascade)
  child  Client @relation("ClientSubClientChild", fields: [childClientId], references: [id], onDelete: Cascade)

  @@unique([parentClientId, childClientId])
  @@index([parentClientId])
  @@index([childClientId])
  @@map("client_sub_clients")
}

model Country {
  code                          String                         @id
  name                          String
  region                        String
  callingCode                   String
  currency                      String
  timezone                      String
  isActive                      Boolean                        @default(true)
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  projects                      Project[]
  qualificationCountryProfiles  QualificationCountryProfile[]
  qualificationEquivalencies    QualificationEquivalency[]
  roleRecommendedQualifications RoleRecommendedQualification[]
  countryDocumentRequirements   CountryDocumentRequirement[]
  processingCountrySteps        ProcessingCountryStep[]
  candidatePreferences          CandidatePreferredCountry[]
  clientsPhysicalAddress        Client[]                       @relation("PhysicalAddressCountryClient")
  usersPhysicalAddress          User[]                         @relation("PhysicalAddressCountryUser")
  candidatesPhysicalAddress     Candidate[]                    @relation("PhysicalAddressCountryCandidate")
  userCountryCoverages          UserCountryCoverage[]
  workExperiences               WorkExperience[]               @relation("WorkExperienceCountry")
  candidateQualifications       CandidateQualification[]       @relation("CandidateQualificationCountry")
  agents                        Agent[]                        @relation("AgentCountry")

  @@map("countries")
}

model Project {
  id                        String    @id @default(cuid())
  clientId                  String?
  title                     String
  description               String?
  deadline                  DateTime?
  // Whether this project requires additional candidate screening steps
  requiredScreening         Boolean   @default(false)
  status                    ProjectStatus    @default(IN_PROGRESS)
  createdBy                 String
  teamId                    String?
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  priority                  String    @default("medium")
  countryCode               String?
  projectType               String    @default("private") // "private" or "ministry"
  resumeEditable            Boolean   @default(true) // Whether resume can be edited according to requirements
  sector                    String    @default("healthcare") // "healthcare" or "non-healthcare"
  groomingRequired          String    @default("formal") // "formal", "casual", "not_specified"
  hideContactInfo           Boolean   @default(true) // Hide email and mobile in resume for private projects
  introductionVideoRequired Boolean   @default(false) // Whether recruiters must upload a candidate introduction video

  // Licensing and Verification
  licensingExam String?
  dataFlow      Boolean? @default(false)
  eligibility   Boolean? @default(false)

  candidateProjects              CandidateProjects[]
  documentRequirements           DocumentRequirement[]
  interviews                     Interview[]
  client                         Client?                         @relation(fields: [clientId], references: [id])
  country                        Country?                        @relation(fields: [countryCode], references: [code])
  creator                        User                            @relation("ProjectCreator", fields: [createdBy], references: [id])
  team                           Team?                           @relation(fields: [teamId], references: [id])
  rolesNeeded                    RoleNeeded[]
  processingTasks                ProcessingCandidate[]
  mergedDocuments                MergedDocument[]
  documentForwards               DocumentForwardHistory[]
  agentProjects                  AgentProject[]
  agentCandidateDeclaredProjects AgentCandidateDeclaredProject[]
  agentCandidateRequests         AgentCandidateRequest[]

  @@map("projects")
}

model RoleNeeded {
  id                         String                           @id @default(cuid())
  projectId                  String
  roleCatalogId              String?
  roleCatalog                RoleCatalog?                     @relation(fields: [roleCatalogId], references: [id], onDelete: SetNull)
  designation                String
  quantity                   Int
  priority                   String                           @default("medium")
  minExperience              Int?
  maxExperience              Int?
  skills                     Json                             @default("[]")
  createdAt                  DateTime                         @default(now())
  updatedAt                  DateTime                         @updatedAt
  additionalRequirements     String?
  backgroundCheckRequired    Boolean                          @default(true)
  benefits                   String?
  drugScreeningRequired      Boolean                          @default(true)
  educationRequirements      Json?
  institutionRequirements    String?
  languageRequirements       Json?
  licenseRequirements        Json?
  notes                      String?
  onCallRequired             Boolean                          @default(false)
  physicalDemands            String?
  relocationAssistance       Boolean                          @default(false)
  requiredCertifications     Json?
  minSalaryRange             Int?
  maxSalaryRange             Int?
  shiftType                  String?
  specificExperience         Json?
  employmentType             String                           @default("permanent") // "contract" or "permanent"
  contractDurationYears      Int? // Only applicable if employmentType is "contract"
  genderRequirement          String                           @default("all") // "female", "male", or "all"
  minAge                     Int
  maxAge                     Int
  accommodation              Boolean?
  food                       Boolean?
  transport                  Boolean?
  target                     Int?
  technicalSkills            Json?
  visaType                   String                           @default("company_visa") // "company_visa", "direct_visa" (legacy: contract, permanent)
  requiredSkills             Json                             @default("[]") // Array of required skills
  candidateStates            Json                             @default("[]") // Array of allowed states for candidates
  candidateReligions         Json                             @default("[]") // Array of allowed religions for candidates
  minHeight                  Float? // Minimum height in cm
  maxHeight                  Float? // Maximum height in cm
  minWeight                  Float? // Minimum weight in kg
  maxWeight                  Float? // Maximum weight in kg
  candidateAllocations       CandidateProjects[]
  educationRequirementsList  RoleNeededEducationRequirement[]
  project                    Project                          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  processingAssignments      ProcessingCandidate[]
  agentCandidateRequestItems AgentCandidateRequestItem[]

  @@index([roleCatalogId])
  @@map("project_roles")
}

model Candidate {
  id                  String           @id @default(cuid())
  candidateCode       String?          @unique @map("candidate_code")
  email               String?
  source              String           @default("manual")
  agentId             String?
  agent               Agent?           @relation("AgentToCandidate", fields: [agentId], references: [id])
  dateOfBirth         DateTime?
  gender              Gender?
  currentStatusId     Int?
  currentStatus       CandidateStatus? @relation(fields: [currentStatusId], references: [id])
  experience          Int?
  skills              Json             @default("[]")
  currentEmployer     String?
  expectedMinSalary   Int?
  expectedMaxSalary   Int?
  sectorType          String?
  visaType            String?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  teamId              String?
  onHoldDuration      Int?             @default(0)
  onHoldUntil         DateTime?
  futureDate          DateTime?
  profileImage        String?
  currentRole         String?
  currentSalary       Int?
  firstName           String
  gpa                 Float?
  graduationYear      Int?
  highestEducation    String?
  lastName            String
  /// “total experience” entered by the recruiter/candidate.  use this value
  /// when it is set – it lets us account for career breaks, gaps, etc.
  totalExperience     Int?
  university          String?
  countryCode         String?
  mobileNumber        String?
  /// Intake passport number (Agent Coordinator create); also checked against passport documents.
  passportNumber      String?          @map("passport_number")
  candidateContacts   Json             @default("[]") @map("candidate_contacts")
  referralCompanyName String?
  referralCountryCode String?
  referralEmail       String?
  referralPhone       String?
  referralDescription String?

  // Physical and Personal attributes
  height              Float?
  weight              Float?
  skinTone            String?
  languageProficiency String?
  smartness           String?

  // Licensing and Verification
  licensingExam String?
  dataFlow      Boolean? @default(false)
  eligibility   Boolean? @default(false)

  professionTypeId String
  professionType   ProfessionType @relation(fields: [professionTypeId], references: [id])

  projects             CandidateProjects[]
  qualifications       CandidateQualification[]
  preferredCountries   CandidatePreferredCountry[]
  facilityPreferences  CandidateFacilityPreference[]
  rolePreferences      CandidateRolePreference[]
  team                 Team?                          @relation(fields: [teamId], references: [id])
  certifications       Certification[]
  documents            Document[]
  talentPool           TalentPool?
  workExperiences      WorkExperience[]
  recruiterAssignments CandidateRecruiterAssignment[]
  statusHistories      CandidateStatusHistory[]       @relation("CandidateToHistory")
  rnrReminders         RNRReminder[]
  callbackReminders    CallbackReminder[]
  processingTasks      ProcessingCandidate[]

  // Meta leads received for this candidate (incoming lead forms)
  metaLeads        MetaLead[]
  mergedDocuments  MergedDocument[]
  documentForwards DocumentForwardHistory[]

  /// Declared client projects for agent-channel candidates only (intent; not nomination / candidate_projects).
  agentCandidateDeclaredProjects AgentCandidateDeclaredProject[]

  addressCountryCode String?
  addressStateId     String?
  address            String?
  addressCountry     Country? @relation("PhysicalAddressCountryCandidate", fields: [addressCountryCode], references: [code], onDelete: SetNull)
  addressState       State?   @relation("PhysicalAddressStateCandidate", fields: [addressStateId], references: [id], onDelete: SetNull)

  @@unique([countryCode, mobileNumber])
  @@index([teamId])
  @@index([currentStatusId])
  @@index([addressCountryCode])
  @@index([addressStateId])
  @@index([countryCode, mobileNumber])
  @@index([createdAt])
  @@index([source])
  @@index([agentId])
  @@index([gender])
  @@index([candidateCode])
  @@index([passportNumber])
  @@index([professionTypeId])
  @@map("candidates")
}

model ProfessionType {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidates           Candidate[]
  userProfessionScopes UserProfessionScope[]

  @@index([isActive])
  @@map("profession_types")
}

model UserProfessionScope {
  id               String   @id @default(cuid())
  userId           String
  professionTypeId String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  professionType ProfessionType @relation(fields: [professionTypeId], references: [id], onDelete: Restrict)

  @@unique([userId, professionTypeId])
  @@index([userId])
  @@index([professionTypeId])
  @@map("user_profession_scopes")
}

model CandidateCodeSequence {
  year       Int @id
  lastNumber Int @default(0) @map("last_number")

  @@map("candidate_code_sequences")
}

model Agent {
  id              String   @id @default(cuid())
  name            String
  email           String?  @unique
  mobileNumber    String?
  whatsappNumber  String?
  alternatePhone1 String?
  alternatePhone2 String?
  companyName     String?
  location        String?
  agentType       String?
  countryCode     String?
  profileImage    String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  country       Country?       @relation("AgentCountry", fields: [countryCode], references: [code], onDelete: SetNull)
  candidates    Candidate[]    @relation("AgentToCandidate")
  agentProjects AgentProject[]

  @@index([countryCode])
  @@map("agents")
}

model AgentProject {
  id        String   @id @default(cuid())
  agentId   String
  projectId String
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  agent   Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([agentId, projectId])
  @@index([agentId])
  @@index([projectId])
  @@map("agent_projects")
}

/// Optional intent: which client projects an agent-supplied candidate is scoped to, before nomination.
model AgentCandidateDeclaredProject {
  id          String   @id @default(cuid())
  candidateId String
  projectId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([candidateId, projectId])
  @@index([candidateId])
  @@index([projectId])
  @@map("agent_candidate_declared_projects")
}

model CandidatePreferredCountry {
  id          String @id @default(cuid())
  candidateId String
  countryCode String

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  country   Country   @relation(fields: [countryCode], references: [code])

  @@unique([candidateId, countryCode])
  @@index([candidateId])
  @@map("candidate_preferred_countries")
}

model CandidateFacilityPreference {
  id           String @id @default(cuid())
  candidateId  String
  facilityType String

  candidate Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@index([candidateId])
  @@map("candidate_facility_preferences")
}

model CandidateRolePreference {
  id            String @id @default(cuid())
  candidateId   String
  roleCatalogId String

  candidate   Candidate   @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  roleCatalog RoleCatalog @relation(fields: [roleCatalogId], references: [id])

  @@unique([candidateId, roleCatalogId])
  @@index([candidateId])
  @@index([roleCatalogId])
  @@map("candidate_role_preferences")
}

model WorkExperience {
  id            String       @id @default(cuid())
  candidateId   String
  roleCatalogId String?
  companyName   String?
  jobTitle      String
  startDate     DateTime
  endDate       DateTime?
  isCurrent     Boolean      @default(false)
  description   String?
  salary        Int?
  location      String?
  countryCode   String?
  skills        Json         @default("[]")
  achievements  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  candidate     Candidate    @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  roleCatalog   RoleCatalog? @relation(fields: [roleCatalogId], references: [id], onDelete: Cascade)
  country       Country?     @relation("WorkExperienceCountry", fields: [countryCode], references: [code], onDelete: SetNull)

  documents Document[]

  @@index([candidateId])
  @@index([roleCatalogId])
  @@index([companyName])
  @@index([jobTitle])
  @@index([countryCode])
  @@map("work_experiences")
}

model CandidateQualification {
  id              String        @id @default(cuid())
  candidateId     String
  qualificationId String
  university      String?
  graduationYear  Int?
  gpa             Float?
  isCompleted     Boolean       @default(true)
  notes           String?
  countryCode     String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  candidate       Candidate     @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)
  country         Country?      @relation("CandidateQualificationCountry", fields: [countryCode], references: [code], onDelete: SetNull)

  @@index([candidateId])
  @@index([qualificationId])
  @@index([countryCode])
  @@map("candidate_qualifications")
}

model CandidateProjects {
  id           String   @id @default(cuid())
  candidateId  String
  projectId    String
  roleNeededId String?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Current status tracking
  currentProjectStatusId Int                    @default(1) // Default to first status (e.g., "nominated")
  currentProjectStatus   CandidateProjectStatus @relation("CurrentProjectStatus", fields: [currentProjectStatusId], references: [id])

  mainStatusId String?
  mainStatus   CandidateProjectMainStatus? @relation(fields: [mainStatusId], references: [id])

  subStatusId String?
  subStatus   CandidateProjectSubStatus? @relation(fields: [subStatusId], references: [id])

  // Store LAST ACTIVE status (before any blocking) for reactivation
  // Preserved through multiple On Hold/Withdrawn changes
  previousMainStatusId String?
  previousMainStatus   CandidateProjectMainStatus? @relation("PreviousMainStatus", fields: [previousMainStatusId], references: [id])

  previousSubStatusId String?
  previousSubStatus   CandidateProjectSubStatus? @relation("PreviousSubStatus", fields: [previousSubStatusId], references: [id])

  // Timestamp when status was FIRST blocked (not updated on subsequent blocks)
  statusBlockedAt DateTime?

  // Recruiter assignment
  assignedAt  DateTime?
  recruiterId String?
  recruiter   User?     @relation(fields: [recruiterId], references: [id])

  // Relations
  documentVerifications CandidateProjectDocumentVerification[]
  candidate             Candidate                              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  project               Project                                @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleNeeded            RoleNeeded?                            @relation(fields: [roleNeededId], references: [id])
  interviews            Interview[]
  projectStatusHistory  CandidateProjectStatusHistory[]
  statusChangeRequests CandidateProjectStatusChangeRequest[]

  // Screening & Training Relations
  screenings          Screening[]
  trainingAssignments ScreeningTraining[]
  processing          ProcessingCandidate?

  @@unique([candidateId, projectId, roleNeededId])
  @@index([currentProjectStatusId])
  @@index([mainStatusId])
  @@index([subStatusId])
  @@index([recruiterId])
  @@index([projectId, roleNeededId])
  @@index([candidateId, projectId])
  @@map("candidate_projects")
}

model Document {
  id          String  @id @default(cuid())
  candidateId String
  docType     String
  /// Human-friendly display name for the document (e.g., "Aster", "ABC Hospital")
  docName     String?
  fileName    String
  fileUrl     String
  uploadedBy  String
  verifiedBy  String?

  status String @default("pending") // "pending", "verified", "rejected"

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  documentNumber   String?
  expiryDate       DateTime?
  fileSize         Int?
  mimeType         String?
  roleCatalogId    String?
  workExperienceId String?

  rejectedAt      DateTime?
  rejectedBy      String?
  rejectionReason String?
  verifiedAt      DateTime?

  verifications  CandidateProjectDocumentVerification[]
  candidate      Candidate                              @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  roleCatalog    RoleCatalog?                           @relation(fields: [roleCatalogId], references: [id], onDelete: Cascade)
  workExperience WorkExperience?                        @relation(fields: [workExperienceId], references: [id], onDelete: SetNull)

  @@index([candidateId])
  @@index([docType])
  @@index([docName])
  @@index([status])
  @@index([roleCatalogId])
  @@index([workExperienceId])
  @@map("documents")
}

model Interview {
  id                    String             @id @default(cuid())
  scheduledTime         DateTime
  duration              Int                @default(60)
  outcome               String?
  notes                 String?
  location              String?
  airTicket             String?
  accommodation         Boolean            @default(false)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  candidateProjectMapId String?
  projectId             String?
  interviewerEmail      String?
  meetingLink           String?
  mode                  String?            @default("video")
  completedAt           DateTime?
  candidateProjectMap   CandidateProjects? @relation(fields: [candidateProjectMapId], references: [id], onDelete: Cascade)
  project               Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  // history is stored in InterviewStatusHistory (polymorphic via interviewType/interviewId)

  @@index([candidateProjectMapId])
  @@index([projectId])
  @@index([scheduledTime])
  @@map("interviews")
}

/// screening Interview Coordination Feature Models
/// Added: January 2025

/// screening Interview - Conducted by Interview Coordinators before client interviews
model Screening {
  id                    String  @id @default(cuid())
  candidateProjectMapId String
  coordinatorId         String // Interview Coordinator who conducts the screening
  templateId            String? // Selected template for this screening

  // Whether a trainer/coach has been assigned
  isAssignedTrainer Boolean @default(false)

  status String @default("scheduled")

  // Scheduling
  scheduledTime DateTime?
  duration      Int       @default(60) // in minutes
  meetingLink   String?
  mode          String    @default("video") // video, phone, in-person

  // Assessment
  conductedAt        DateTime?
  overallRating      Int? // 1-5 scale
  decision           String? // approved, needs_training, rejected
  remarks            String?   @db.Text
  strengths          String?   @db.Text
  areasOfImprovement String?   @db.Text

  // Additional assessment metrics
  goodLooking         Int? // 1-5 scale
  fairness            Int? // 1-5 scale
  languageProficiency String?

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  coordinator         User                     @relation("ScreeningCoordinator", fields: [coordinatorId], references: [id])
  candidateProjectMap CandidateProjects        @relation(fields: [candidateProjectMapId], references: [id], onDelete: Cascade)
  template            ScreeningTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  checklistItems      ScreeningChecklistItem[]
  trainingAssignments ScreeningTraining[]
  // history is stored in InterviewStatusHistory (polymorphic via interviewType/interviewId)

  @@index([candidateProjectMapId])
  @@index([coordinatorId])
  @@index([templateId])
  @@index([scheduledTime])
  @@index([decision])
  @@map("screenings")
}

/// Checklist items for each screening interview (filled during/after interview)
/// Links to template item if answer came from a template, otherwise custom question
model ScreeningChecklistItem {
  id             String  @id @default(cuid())
  screeningId    String
  templateItemId String? // Optional: Link to template item if from template

  category  String // technical_skills, communication, professionalism, role_specific
  criterion String // What was evaluated
  passed    Boolean @default(false)
  rating    Int? // 1-5 scale
  score     Float? // numeric score (e.g., percentage or points)
  notes     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  screening    Screening              @relation(fields: [screeningId], references: [id], onDelete: Cascade)
  templateItem ScreeningTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@index([screeningId])
  @@index([templateItemId])
  @@index([category])
  @@map("screening_checklist_items")
}

/// Screening Interview Template - A named collection of questions for a role
/// Interview Coordinators can create multiple templates per role
/// Each template contains questions organized by categories
model ScreeningTemplate {
  id     String       @id @default(cuid())
  roleId String?
  role   RoleCatalog? @relation(fields: [roleId], references: [id], onDelete: Cascade)

  name        String
  description String?
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items      ScreeningTemplateItem[]
  screenings Screening[]

  @@unique([roleId, name])
  @@index([roleId])
  @@index([isActive])
  @@map("screening_templates")
}

/// Questions/Criteria within a template, organized by category
/// Each template can have multiple categories, each category can have multiple questions
/// No duplicate categories within a single template (enforced by application logic)
model ScreeningTemplateItem {
  id         String            @id @default(cuid())
  templateId String
  template   ScreeningTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  category  String // technical_skills, communication, professionalism, role_specific
  criterion String // The question/criterion to evaluate
  order     Int    @default(0) // Order within category

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  checklistItems ScreeningChecklistItem[] // Answers that used this template item

  @@unique([templateId, category, criterion]) // Prevent duplicate criteria in same category
  @@index([templateId])
  @@index([category])
  @@map("screening_template_items")
}

/// InterviewStatusHistory
/// Stores history events for both Screening and Interview (client/main) entities.
model InterviewStatusHistory {
  id String @id @default(cuid())

  // Type of interview (e.g. 'screening' | 'client') and the corresponding interview id
  interviewType String
  interviewId   String?

  // Link to the candidate-project map (optional)
  candidateProjectMapId String?

  // Previous status code (nullable) and the new status code
  previousStatus String?
  status         String
  statusSnapshot String? @db.Text

  // When the status/event occurred
  statusAt DateTime @default(now())

  // Who caused the change (snapshot)
  changedById   String?
  changedBy     User?   @relation("UserToInterviewStatusHistory", fields: [changedById], references: [id])
  changedByName String?

  // Reason / short text
  reason String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([interviewType, interviewId])
  @@index([candidateProjectMapId])
  @@index([changedById])
  @@index([statusAt])
  @@map("interview_status_history")
}

/// Screening training records for candidates who need improvement
model ScreeningTraining {
  id                    String  @id @default(cuid())
  candidateProjectMapId String
  screeningId           String? // Which screening triggered this
  assignedBy            String // Coordinator who assigned training
  trainerId             String? // Trainer user ID conducting this training

  // Training details
  focusAreas    String[] // Areas to improve
  priority      String   @default("medium") // high, medium, low
  status        String   @default("assigned") // assigned, scheduled, in_progress, passed, failed, retraining, cancelled
  attemptNumber Int      @default(1)

  // Schedule / session metadata
  scheduledTime DateTime?
  duration      Int?
  meetingLink   String?
  sessionType   String?

  // Dates
  assignedAt           DateTime  @default(now())
  startedAt            DateTime?
  completedAt          DateTime?
  targetCompletionDate DateTime?

  // Assessment after training
  notes            String? @db.Text
  improvementNotes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  candidateProjectMap CandidateProjects @relation(fields: [candidateProjectMapId], references: [id], onDelete: Cascade)
  screening           Screening?        @relation(fields: [screeningId], references: [id], onDelete: SetNull)

  @@index([candidateProjectMapId])
  @@index([screeningId])
  @@index([assignedBy])
  @@index([status])
  @@map("training_assignments")
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  seen      Boolean   @default(false)
  createdAt DateTime  @default(now())
  idemKey   String    @unique
  link      String?
  meta      Json?
  readAt    DateTime?
  status    String    @default("unread")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([type])
  @@index([status])
  @@map("notifications")
}

model OutboxEvent {
  id        String   @id @default(cuid())
  type      String
  payload   Json
  processed Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([type])
  @@index([processed])
  @@map("outbox_events")
}

enum MetaLeadStatus {
  pending
  linked
  skipped
  fraud
  review
  processed
}

enum AgentCandidateRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AgentCandidateRequest {
  id            String                      @id @default(cuid())
  projectId     String
  requestedById String
  status        AgentCandidateRequestStatus @default(PENDING)
  notes         String?
  createdAt     DateTime                    @default(now())
  updatedAt     DateTime                    @updatedAt

  project     Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  requestedBy User                        @relation("AgentCandidateRequestRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  items       AgentCandidateRequestItem[]

  @@index([projectId, status, createdAt])
  @@index([requestedById, createdAt])
  @@map("agent_candidate_requests")
}

model AgentCandidateRequestItem {
  id             String   @id @default(cuid())
  requestId      String
  roleNeededId   String
  requestedCount Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  request    AgentCandidateRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  roleNeeded RoleNeeded            @relation(fields: [roleNeededId], references: [id], onDelete: Restrict)

  @@unique([requestId, roleNeededId])
  @@index([requestId])
  @@index([roleNeededId])
  @@map("agent_candidate_request_items")
}

model MetaLead {
  id                 String         @id @default(cuid())
  leadId             String?        @unique
  formId             String?
  campaignId         String?
  adsetId            String?
  adId               String?
  fullName           String?
  firstName          String?
  lastName           String?
  email              String?        @db.VarChar(254)
  countryCode        String?
  phoneNumber        String?
  formSubmissionTime DateTime?
  rawPayload         Json?
  status             MetaLeadStatus @default(pending)
  source             String?        @default("meta")
  platform           String? // "facebook", "instagram", "whatsapp"
  senderId           String? // PSID or Phone Number
  shortCode          String?        @unique // nanoid generated
  tokenExpiresAt     DateTime?
  consentGiven       Boolean?       @default(false)
  consentAt          DateTime?
  candidateId        String?
  processingNote     String?
  createdAt          DateTime       @default(now())
  processedAt        DateTime?
  erasedAt           DateTime?

  candidate Candidate? @relation(fields: [candidateId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([countryCode, phoneNumber])
  @@index([status])
  @@index([shortCode])
  @@map("meta_leads")
}

model TeamTransferRequest {
  id          String    @id @default(cuid())
  userId      String
  fromTeamId  String
  toTeamId    String
  requestedBy String
  status      String    @default("pending")
  reason      String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  approver    User?     @relation("TransferApprover", fields: [approvedBy], references: [id])
  fromTeam    Team      @relation("FromTeamTransfers", fields: [fromTeamId], references: [id], onDelete: Cascade)
  requester   User      @relation("TransferRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  toTeam      Team      @relation("ToTeamTransfers", fields: [toTeamId], references: [id], onDelete: Cascade)
  user        User      @relation("TransferUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([fromTeamId])
  @@index([toTeamId])
  @@index([status])
  @@map("team_transfer_requests")
}

model CandidateProjectStatusChangeRequest {
  id                    String   @id @default(cuid())
  candidateProjectMapId String
  candidateProjectMap   CandidateProjects @relation(fields: [candidateProjectMapId], references: [id], onDelete: Cascade)
  
  // Request type: 'block' (to Withdrawn/On Hold) or 'reactivate' (return to last active)
  requestType           String   @default("block")
  
  requestedStatus       String
  reason                String   @db.Text
  status                String   @default("pending")
  requestedBy           String
  requester             User     @relation("StatusChangeRequester", fields: [requestedBy], references: [id], onDelete: Cascade)
  reviewedBy            String?
  reviewer              User?    @relation("StatusChangeReviewer", fields: [reviewedBy], references: [id])
  reviewedAt            DateTime?
  reviewNotes           String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([candidateProjectMapId, status])
  @@index([requestedBy])
  @@index([status])
  @@index([requestType])
  @@map("candidate_project_status_change_requests")
}

model Certification {
  id                 String    @id @default(cuid())
  candidateId        String
  certName           String
  status             String    @default("pending")
  examDate           DateTime?
  validUntil         DateTime?
  exportedToLearning Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  candidate          Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("certifications")
}

model TalentPool {
  id              String    @id @default(cuid())
  candidateId     String    @unique
  role            String
  yearsExperience Int
  currentEmployer String?
  isAvailable     Boolean   @default(true)
  rating          Int?
  notes           String?
  sourceProjectId String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  candidate       Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  @@map("talent_pool")
}

/// *
/// * DocumentRequirement
/// * Defines what documents are required for a specific project
/// * Set by recruiter/manager when creating/updating a project
model DocumentRequirement {
  id          String    @id @default(cuid())
  projectId   String
  docType     String
  mandatory   Boolean   @default(true)
  description String?
  isAutomatic Boolean   @default(false)
  isDeleted   Boolean   @default(false)
  deletedAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([isDeleted])
  @@map("document_requirements")
}

/// *
/// * CandidateProjectDocumentVerification
/// * Junction table linking Documents to specific Project nominations
/// * Tracks verification status of each document for each project
/// * Multiple projects can reference the same document (e.g., same passport for multiple projects)
model CandidateProjectDocumentVerification {
  id                    String  @id @default(cuid())
  candidateProjectMapId String
  documentId            String
  roleCatalogId         String?

  // Document status inside this project
  status String @default("pending")
  // "pending" | "verified" | "rejected" | "resubmission_requested"

  offerLetterReceivedAt DateTime?
  receivedAt            DateTime?

  notes                 String?
  rejectionReason       String?
  resubmissionRequested Boolean @default(false)
  isReuploaded          Boolean @default(false)

  isUploadedByProcessingTeam Boolean @default(false)
  isProcessingReplaced       Boolean @default(false)

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  candidateProjectMap CandidateProjects @relation(fields: [candidateProjectMapId], references: [id], onDelete: Cascade)
  document            Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  roleCatalog         RoleCatalog?      @relation(fields: [roleCatalogId], references: [id], onDelete: Cascade)

  verificationHistory     DocumentVerificationHistory[]
  processingStepDocuments ProcessingStepDocument[]

  @@unique([candidateProjectMapId, documentId])
  @@index([candidateProjectMapId])
  @@index([documentId])
  @@index([roleCatalogId])
  @@index([status])
  @@map("candidate_project_document_verifications")
}

/// *
/// * DocumentVerificationHistory
/// * Tracks all verification actions on documents
/// * Records who performed the action, when, and why
model DocumentVerificationHistory {
  id             String  @id @default(cuid())
  verificationId String?

  action String // "verified", "rejected", "resubmission_requested", "pending"

  performedBy     String
  performedByName String?

  notes       String?
  reason      String?
  performedAt DateTime @default(now())

  verification CandidateProjectDocumentVerification? @relation(fields: [verificationId], references: [id], onDelete: Cascade)
  performer    User                                  @relation("DocumentVerificationPerformer", fields: [performedBy], references: [id])

  @@index([verificationId])
  @@index([performedBy])
  @@index([action])
  @@index([performedAt])
  @@map("document_verification_history")
}

/// *
/// * ProjectRole
/// * Catalog of roles that can be assigned to projects
/// * Simple role definitions with name and category
// ProjectRole model removed. Previously mapped to `project_role_catalog`.

/// *
/// * RoleCatalog
/// * Normalized catalog of healthcare and general staff roles
/// * Separate from system RBAC roles (Role model)
model RoleCatalog {
  id               String         @id @default(cuid())
  roleDepartmentId String
  roleDepartment   RoleDepartment @relation(fields: [roleDepartmentId], references: [id], onDelete: Cascade)
  name             String         @unique
  label            String
  type             String         @default("other")
  shortName        String?
  description      String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  recommendedQualifications RoleRecommendedQualification[]
  screeningTemplates        ScreeningTemplate[]
  roleNeededEntries         RoleNeeded[]
  documentVerifications     CandidateProjectDocumentVerification[]
  documents                 Document[]
  // Work experiences linked to this role catalog
  workExperiences           WorkExperience[]
  mergedDocuments           MergedDocument[]
  documentForwards          DocumentForwardHistory[]
  candidateRolePreferences  CandidateRolePreference[]

  @@index([roleDepartmentId])
  @@index([isActive])
  @@map("role_catalog")
}

model RoleDepartment {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  shortName   String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Opposite relation: list of roles in this department
  roles RoleCatalog[]

  @@index([isActive])
  @@map("role_departments")
}

/// *
/// * Qualification
/// * Normalized catalog of educational qualifications, degrees, and certifications
model Qualification {
  id                      String                           @id @default(cuid())
  name                    String                           @unique
  shortName               String?
  level                   QualificationLevel
  field                   String
  program                 String?
  description             String?
  isActive                Boolean                          @default(true)
  createdAt               DateTime                         @default(now())
  updatedAt               DateTime                         @updatedAt
  candidateQualifications CandidateQualification[]
  aliases                 QualificationAlias[]
  countryProfiles         QualificationCountryProfile[]
  equivalencies           QualificationEquivalency[]       @relation("FromQualification")
  reverseEquivalencies    QualificationEquivalency[]       @relation("ToQualification")
  roleNeededRequirements  RoleNeededEducationRequirement[]
  roleRecommendations     RoleRecommendedQualification[]

  @@index([level])
  @@index([field])
  @@index([isActive])
  @@map("qualifications")
}

/// *
/// * QualificationAlias
/// * Alternative names for qualifications (e.g., "RN" for "Registered Nurse")
model QualificationAlias {
  id              String        @id @default(cuid())
  qualificationId String
  alias           String
  isCommon        Boolean       @default(false)
  createdAt       DateTime      @default(now())
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@unique([qualificationId, alias])
  @@index([alias])
  @@map("qualification_aliases")
}

/// *
/// * QualificationCountryProfile
/// * Country-specific information for qualifications
model QualificationCountryProfile {
  id                  String        @id @default(cuid())
  qualificationId     String
  countryCode         String
  regulatedTitle      String?
  issuingBody         String?
  accreditationStatus String?
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  country             Country       @relation(fields: [countryCode], references: [code])
  qualification       Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)

  @@unique([qualificationId, countryCode])
  @@index([countryCode])
  @@map("qualification_country_profiles")
}

/// *
/// * QualificationEquivalency
/// * Cross-qualification equivalence mapping
model QualificationEquivalency {
  id                  String        @id @default(cuid())
  fromQualificationId String
  toQualificationId   String
  countryCode         String?
  isEquivalent        Boolean       @default(true)
  notes               String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  country             Country?      @relation(fields: [countryCode], references: [code])
  fromQualification   Qualification @relation("FromQualification", fields: [fromQualificationId], references: [id], onDelete: Cascade)
  toQualification     Qualification @relation("ToQualification", fields: [toQualificationId], references: [id], onDelete: Cascade)

  @@unique([fromQualificationId, toQualificationId, countryCode])
  @@index([fromQualificationId])
  @@index([toQualificationId])
  @@map("qualification_equivalencies")
}

/// *
/// * RoleRecommendedQualification
/// * Mapping of recommended qualifications for specific roles
model RoleRecommendedQualification {
  id              String        @id @default(cuid())
  roleId          String
  qualificationId String
  weight          Int           @default(1)
  countryCode     String?
  isPreferred     Boolean       @default(false)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  country         Country?      @relation(fields: [countryCode], references: [code])
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)
  role            RoleCatalog   @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, qualificationId, countryCode])
  @@index([roleId])
  @@index([qualificationId])
  @@index([weight])
  @@map("role_recommended_qualifications")
}

/// *
/// * RoleNeededEducationRequirement
/// * Junction table linking RoleNeeded to specific Qualifications
/// * Replaces free-text educationRequirements with normalized IDs
model RoleNeededEducationRequirement {
  id              String        @id @default(cuid())
  roleNeededId    String
  qualificationId String
  mandatory       Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  qualification   Qualification @relation(fields: [qualificationId], references: [id], onDelete: Cascade)
  roleNeeded      RoleNeeded    @relation(fields: [roleNeededId], references: [id], onDelete: Cascade)

  @@unique([roleNeededId, qualificationId])
  @@index([roleNeededId])
  @@index([qualificationId])
  @@map("role_needed_education_requirements")
}

model AuditLog {
  id         String   @id @default(cuid())
  actionType String
  entityId   String
  entityType String
  userId     String
  changes    Json     @default("{}")
  timestamp  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}

model AllocationCursor {
  id           String   @id @default(cuid())
  projectId    String
  roleNeededId String
  lastIndex    Int      @default(0)
  updatedAt    DateTime @updatedAt

  @@unique([projectId, roleNeededId])
  @@map("allocation_cursors")
}

