# Copy to backend/.env (never commit .env)
# Same file for local dev, Docker dev, and Docker production — use different values per machine.

# Database (native npm dev only — Docker compose overrides DATABASE_URL at runtime)
DATABASE_URL="postgresql://postgres:password@localhost:5432/affiniks_rms?schema=public"

# PostgreSQL (Docker postgres service)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=affiniks_rms

# Redis (native npm dev only — Docker compose overrides REDIS_* at runtime)
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# App
PORT=3000
NODE_ENV=development

# CORS — comma-separated allowed frontend origins (no trailing slash)
CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
# Production example:
# CORS_ORIGIN="https://rms.affiniks.com"

# Public URLs (production Docker web build — dev Docker web uses compose defaults)
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=http://localhost:3000

# Seed / logging
SEED_ADMIN_PASSWORD=admin123
LOG_LEVEL=info

# DigitalOcean Spaces
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_ENDPOINT=
DO_SPACES_REGION=
DO_SPACES_SYNC_CORS=false

# Meta / Facebook
META_VERIFY_TOKEN=
META_GRAPH_VERSION=v21.0
META_PAGE_ID=
META_PAGE_ACCESS_TOKEN=

# Instagram Messaging
META_IG_ACCOUNT_ID=
INSTAGRAM_PAGE_ACCESS_TOKEN=

# WhatsApp
WHATSAPP_ENABLED=true
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_API_URL=https://graph.facebook.com/v24.0/

# MSG91 OTP
MSG91_AUTHKEY=
MSG91_SENDERID=
MSG91_TEMPLATEID=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Google Drive (if used)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=
# GOOGLE_PRIVATE_KEY=
# GOOGLE_DRIVE_PARENT_FOLDER_ID=
